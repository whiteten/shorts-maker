# ===== 스크립트 생성 =====
# claude_cli = Claude Max 구독으로 생성(키 불필요, 품질↑, 추천)
# ollama     = 로컬 무료(qwen2.5) / claude = Anthropic API(유료)
SCRIPT_BACKEND=claude_cli
CLAUDE_CLI_MODEL=claude-sonnet-5
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# claude(API) 백엔드 쓸 때만
ANTHROPIC_API_KEY=
SCRIPT_MODEL=claude-opus-4-8

# ===== 영상 생성 =====
# stock  : 실사 스톡 푸티지 Pexels (무료 키, 완전자동, 추천)
# auto   : 무료 이미지 생성 + 모션 (완전 자동)
# manual : Flow에서 손으로 클립 생성 (무료, 구독 활용)
# veo    : Gemini Veo API (완전 자동, 초당 과금)
VIDEO_SOURCE=stock
PEXELS_API_KEY=
IMAGE_BACKEND=pollinations
GEMINI_API_KEY=
VEO_MODEL=veo-3.1-fast-generate-preview

# ===== 콘텐츠 =====
LANGUAGE=ko
SHORT_SECONDS=45
TTS_VOICE=ko-KR-SunHiNeural

# ===== YouTube 업로드 =====
YOUTUBE_CLIENT_SECRET=client_secret.json
YOUTUBE_PRIVACY=private
YOUTUBE_CATEGORY_ID=24
